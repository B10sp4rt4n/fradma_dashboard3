# ===================================================================
# FRADMA DASHBOARD - VARIABLES DE ENTORNO (PLANTILLA)
# ===================================================================
# Renombrar este archivo a .env y completar los valores.
# IMPORTANTE: .env NO debe subirse a git (está en .gitignore).
# En Railway: cargar estas variables en Settings > Variables.
# ===================================================================

# ------------------------------------------------------------------
# BASE DE DATOS (OBLIGATORIA)
# ------------------------------------------------------------------
# Cadena de conexión a Neon PostgreSQL (multi-tenant)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/fradma?sslmode=require

# ------------------------------------------------------------------
# OPENAI (OPCIONAL — se puede ingresar en la UI)
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------
# SEGURIDAD
# ------------------------------------------------------------------
# Passkey para funciones premium con IA. Cambiar en producción.
PASSKEY_PREMIUM=cambia_este_valor_en_produccion

# ------------------------------------------------------------------
# CONFIGURACIÓN DE APP
# ------------------------------------------------------------------
# Ambiente: development | production
APP_ENV=production

# Nivel de logs: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ------------------------------------------------------------------
# SEGURIDAD DE SESIÓN
# ------------------------------------------------------------------
# Número de intentos fallidos antes de bloqueo temporal (default: 5)
MAX_LOGIN_ATTEMPTS=5

# Duración de la sesión activa en segundos (default: 28800 = 8 horas)
SESSION_TTL_SECONDS=28800

# Duración del bloqueo temporal en segundos (default: 900 = 15 minutos)
LOGIN_LOCKOUT_SECONDS=900

# ------------------------------------------------------------------
# ASISTENTE DE DATOS (OPCIONAL)
# ------------------------------------------------------------------
# Fuente del catálogo guiado: json (default) | db
GUIDED_CATALOG_SOURCE=json

# ===================================================================
# NOTAS:
# - NEON_DATABASE_URL es la única variable obligatoria para arrancar.
# - OPENAI_API_KEY es necesaria para el asistente IA y reportes.
# - PASSKEY_PREMIUM protege funciones de análisis avanzado.
# - Nunca subir .env con valores reales al repositorio.
# ===================================================================
